<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.OrderChangeReceipt" t-inherit-mode="extension">
        <!-- 1. Quitar el encabezado original -->
        <xpath expr="//div[hasclass('receipt-header')]" position="replace"/>
        <xpath expr="//hr" position="replace"/>
        <xpath expr="//t[@t-if='(!changedlines.length or fullReceipt) and changes.order_note.length']" position="replace"/>

        <!-- 2. Quitar el título "New" -->
        <xpath expr="//t[@t-if='operational_title']" position="replace">
            <t t-if="operational_title and operational_title !== 'New'">
                <div class="pos-receipt-title text-center" t-esc="operational_title" />
            </t>
        </xpath>

        <!-- 3. Mostrar Logo y Nombre del Cliente al inicio del cuerpo del ticket -->
        <xpath expr="//div[hasclass('pos-receipt-body')]" position="before">
            <div style="margin-bottom: 10px; padding-bottom: 5px; border-bottom: 1px dashed black;">
                <div class="text-center" style="margin-bottom: 5px;">
                    <t t-if="changes and changes.company_logo">
                        <img class="pos-receipt-logo" t-att-src="changes.company_logo" 
                             style="max-height: 150px; display: block; margin: 0 auto;"/>
                    </t>
                    <t t-elif="changes and changes.company_id">
                        <img class="pos-receipt-logo" t-attf-src="/web/image?model=res.company&amp;id={{changes.company_id}}&amp;field=logo" 
                             style="max-height: 150px; display: block; margin: 0 auto;"/>
                    </t>
                </div>
                
                <!-- Nombre del Cliente (si existe, Alineado a la Izquierda) -->
                <t t-if="changes and changes.partner_name">
                    <div style="font-size: 110%; font-weight: bold; text-align: left; margin-top: 5px;">
                        Cliente: <t t-esc="changes.partner_name"/>
                    </div>
                </t>
            </div>
        </xpath>

        <!-- 4. Formato de Producto: Referencia + Nombre + xUnidad (Usando clases nativas del POS) -->
        <xpath expr="//div[@t-foreach='changedlines']/div/div[hasclass('d-flex')]" position="replace">
            <div class="d-flex medium">
                <t t-if="line and line.default_code">[<t t-esc="line.default_code"/>] </t>
                <span class="product-name" t-esc="line.display_name"/>
                <span> x<t t-esc="line.quantity"/></span>
            </div>
        </xpath>
    </t>

</templates>
